# Environment variables (optional)
# Copy this file to .env and fill in your values

# Public web auth backend used by Expo web builds
# For GitHub Pages, point this to your live Render service
EXPO_PUBLIC_AUTH_API_URL=https://aaramusic.onrender.com

# Firebase Configuration
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Other API Keys
MUSIC_API_KEY=
