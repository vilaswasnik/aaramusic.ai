{
  "name": "aaramusic.ai",
  "version": "1.0.0",
  "description": "Aara Music - Modern Music Streaming App",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "node server.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "bash ./start.sh",
    "web:expo": "expo start --web",
    "build:web": "GITHUB_PAGES=true NODE_ENV=production npx expo export --platform web",
    "build:render": "NODE_ENV=production npx expo export --platform web",
    "build:web:dev": "npx expo export --platform web",
    "serve": "node server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vilaswasnik/aaramusic.ai.git"
  },
  "keywords": [
    "music",
    "streaming",
    "react-native",
    "expo"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vilaswasnik/aaramusic.ai/issues"
  },
  "homepage": "https://github.com/vilaswasnik/aaramusic.ai#readme",
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "expo": "~52.0.0",
    "expo-av": "~15.0.2",
    "expo-blur": "~14.0.3",
    "expo-haptics": "~14.0.1",
    "expo-linear-gradient": "~14.0.2",
    "expo-status-bar": "~2.0.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "react": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "^0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~18.3.12",
    "typescript": "^5.9.3"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
